# Harbor Helm values — minimal footprint
# Managed by Ansible — do not edit manually

expose:
  type: ingress
  tls:
    enabled: true
    certSource: secret
    secret:
      secretName: wildcard-dev-viloforge-tls
  ingress:
    hosts:
      core: harbor.{{ domain }}
    className: traefik
    annotations:
      traefik.ingress.kubernetes.io/router.entrypoints: websecure

externalURL: {{ harbor_external_url }}

harborAdminPassword: "{{ vault_harbor_admin_password }}"

# Minimal footprint — disable optional components
trivy:
  enabled: false

notary:
  enabled: false

chartmuseum:
  enabled: false

# Database — internal Postgres with PVC
database:
  type: internal
  internal:
    resources:
      requests:
        memory: 256Mi
        cpu: 100m
      limits:
        memory: 512Mi
        cpu: 500m

# Redis — internal with minimal resources
redis:
  type: internal
  internal:
    resources:
      requests:
        memory: 64Mi
        cpu: 50m
      limits:
        memory: 128Mi
        cpu: 200m

# Core component resources
core:
  resources:
    requests:
      memory: 256Mi
      cpu: 100m
    limits:
      memory: 512Mi
      cpu: 500m

# Registry component resources
registry:
  resources:
    requests:
      memory: 256Mi
      cpu: 100m
    limits:
      memory: 512Mi
      cpu: 500m

# Persistence — use k3s local-path provisioner
persistence:
  enabled: true
  persistentVolumeClaim:
    registry:
      size: 20Gi
    database:
      size: 2Gi
    redis:
      size: 1Gi
