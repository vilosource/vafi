{
  "hooks": {
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "{{DIR}}/save_hook.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "{{DIR}}/precompact_hook.sh",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
