#!/bin/bash
# claude-mempalace — Claude Code with persistent MemPalace memory
#
# Auth (auto-detected):
#   OAuth: reads ~/.claude/.credentials.json and passes content via env var
#   z.ai:  set ANTHROPIC_AUTH_TOKEN + ANTHROPIC_BASE_URL env vars
#
# Usage:
#   claude-mempalace                          # default palace, current dir
#   claude-mempalace customer-acme            # isolated palace, current dir
#   claude-mempalace customer-acme ~/project  # isolated palace, specific dir
#   claude-mempalace --list                   # list palaces
#   claude-mempalace --delete <name>          # delete a palace volume
set -euo pipefail

IMAGE="${MEMPALACE_IMAGE:-harbor.viloforge.com/vafi/vafi-developer:latest}"
VOLUME_PREFIX="mempalace"

# --- Subcommands ---

if [[ "${1:-}" == "--list" ]]; then
    echo "PALACE              SIZE        CREATED"
    docker volume ls --format '{{.Name}}\t{{.Driver}}' | grep "^${VOLUME_PREFIX}-" | while read -r name _; do
        palace="${name#${VOLUME_PREFIX}-}"
        size=$(docker system df -v 2>/dev/null | grep "$name" | awk '{print $3}' || echo "?")
        created=$(docker volume inspect "$name" --format '{{.CreatedAt}}' 2>/dev/null | cut -d'T' -f1 || echo "?")
        printf "%-20s%-12s%s\n" "$palace" "$size" "$created"
    done
    exit 0
fi

if [[ "${1:-}" == "--delete" ]]; then
    [[ -z "${2:-}" ]] && echo "Usage: claude-mempalace --delete <palace-name>" && exit 1
    docker volume rm "${VOLUME_PREFIX}-${2}" 2>/dev/null && echo "Deleted palace: ${2}" || echo "Palace not found: ${2}"
    exit 0
fi

# --- Resolve workspace ---

PALACE="${1:-default}"
WORKDIR="${2:-.}"
RESOLVED=$(realpath "$WORKDIR")

# Guard: refuse to mount home directory directly
if [ "$RESOLVED" = "$HOME" ]; then
    echo "ERROR: refusing to mount home directory as workspace — use a subdirectory."
    echo "  Example: claude-mempalace $PALACE ~/projects/myapp"
    exit 1
fi

# --- Build docker args ---

env_args=()

# z.ai auth
if [ -n "${ANTHROPIC_AUTH_TOKEN:-}" ]; then
    env_args+=(-e "ANTHROPIC_AUTH_TOKEN=$ANTHROPIC_AUTH_TOKEN")
    [ -n "${ANTHROPIC_BASE_URL:-}" ] && env_args+=(-e "ANTHROPIC_BASE_URL=$ANTHROPIC_BASE_URL")
fi

# OAuth auth: read credentials file and pass content as env var
CREDS="${HOME}/.claude/.credentials.json"
if [ -z "${ANTHROPIC_AUTH_TOKEN:-}" ] && [ -f "$CREDS" ]; then
    env_args+=(-e "CLAUDE_CREDENTIALS=$(cat "$CREDS")")
fi

# GitLab
for gl_var in GITLAB_TOKEN GITLAB_HOST; do
    eval "val=\${${gl_var}:-}"
    [ -n "$val" ] && env_args+=(-e "${gl_var}=${val}")
done

# MediaWiki
for mw_var in MW_API_HOST MW_API_PATH MW_USE_HTTPS MW_BOT_USER MW_BOT_PASS; do
    eval "val=\${${mw_var}:-}"
    [ -n "$val" ] && env_args+=(-e "${mw_var}=${val}")
done

# Auto-init
[ -n "${MEMPALACE_AUTO_INIT:-}" ] && env_args+=(-e "MEMPALACE_AUTO_INIT=$MEMPALACE_AUTO_INIT")

exec docker run -it --rm \
    --name "claude-mp-$$-$(date +%s)" \
    "${env_args[@]}" \
    -v "${VOLUME_PREFIX}-${PALACE}:/home/agent/.mempalace" \
    -v "developer-azure-cache:/home/agent/.azure" \
    -v "${RESOLVED}:/workspace" \
    "$IMAGE"
