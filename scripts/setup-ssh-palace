#!/bin/bash
# Copy SSH config + keys into a palace's home volume.
# Run once per palace, or after key rotation.
#
# Usage: setup-ssh-palace <palace-name>
set -euo pipefail

PALACE="${1:?Usage: setup-ssh-palace <palace-name>}"
VOLUME="mempalace-${PALACE}-home"

# Verify volume exists
if ! docker volume inspect "$VOLUME" &>/dev/null; then
    echo "Volume $VOLUME does not exist. Run the palace once first."
    exit 1
fi

# Copy SSH files into the volume via a temp container
docker run --rm \
    -v "${VOLUME}:/home/agent" \
    -v "${HOME}/.ssh:/host-ssh:ro" \
    alpine sh -c "
        mkdir -p /home/agent/.ssh
        cp /host-ssh/config /home/agent/.ssh/config
        for f in /host-ssh/ansible.priv /host-ssh/azure_ansible /host-ssh/ansible_hyperv_lab /host-ssh/kuja_ed25519 /host-ssh/gitlab_ed25519; do
            [ -f \"\$f\" ] && cp \"\$f\" /home/agent/.ssh/
        done
        # Fix paths
        sed -i 's|/home/jasonvi/.ssh|/home/agent/.ssh|g' /home/agent/.ssh/config
        sed -i 's|~/.ssh|/home/agent/.ssh|g' /home/agent/.ssh/config
        # Copy host known_hosts (includes GitLab etc.)
        [ -f /host-ssh/known_hosts ] && cp /host-ssh/known_hosts /home/agent/.ssh/known_hosts
        chmod 700 /home/agent/.ssh
        chmod 644 /home/agent/.ssh/config /home/agent/.ssh/known_hosts
        chmod 600 /home/agent/.ssh/ansible.priv /home/agent/.ssh/azure_ansible /home/agent/.ssh/ansible_hyperv_lab /home/agent/.ssh/kuja_ed25519 /home/agent/.ssh/gitlab_ed25519 2>/dev/null
        # Fix ownership to agent uid
        chown -R 1001:1001 /home/agent/.ssh
        echo 'SSH files copied to ${VOLUME}'
        ls -la /home/agent/.ssh/
    "
